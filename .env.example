# Copy this file to .env for local testing (never commit your real .env).
# In production these are stored as GitHub Actions repository secrets instead.
#
# You can use Telegram, Discord, or BOTH. Configure whichever you like; the bot
# sends a notification to every channel that has its secret(s) set.

# --- Telegram (optional) ---
# Telegram bot token from @BotFather (looks like 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat id from @userinfobot (a number, e.g. 12345678)
TELEGRAM_CHAT_ID=

# --- Discord (optional) ---
# A Discord channel webhook URL: Server Settings -> Integrations -> Webhooks.
# Looks like https://discord.com/api/webhooks/<id>/<token>
DISCORD_WEBHOOK_URL=
